{
  "name": "@nyaomaru/divider",
  "type": "module",
  "version": "2.0.13",
  "description": "To divide string or string[] with a given separator",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    "import": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "require": {
      "types": "./dist/index.d.cts",
      "default": "./dist/index.cjs"
    }
  },
  "scripts": {
    "test": "jest",
    "test:performance": "jest --config jest.performance.config.cjs",
    "test:unit": "jest --testPathIgnorePatterns=performance",
    "lint": "eslint .",
    "build": "tsup",
    "prepack": "pnpm run build",
    "typedoc": "typedoc",
    "prepare": "lefthook install",
    "knip": "knip"
  },
  "keywords": [
    "divider",
    "divide",
    "split",
    "string",
    "array"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nyaomaru/divider.git"
  },
  "homepage": "https://divider-docs.vercel.app/",
  "author": "nyaomaru",
  "license": "MIT",
  "devDependencies": {
    "@swc/core": "^1.15.21",
    "@swc/jest": "^0.2.39",
    "@eslint/js": "^9.26.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.15.12",
    "@typescript-eslint/eslint-plugin": "^8.32.1",
    "@typescript-eslint/parser": "^8.32.1",
    "bun-types": "^1.2.21",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "jest": "^30.2.0",
    "knip": "^5.82.1",
    "lefthook": "^2.0.13",
    "prettier": "^3.5.3",
    "tsup": "^8.4.0",
    "tsx": "^4.19.4",
    "typedoc": "^0.28.5",
    "typescript": "^5.8.3"
  },
  "pnpm": {
    "overrides": {
      "brace-expansion@<1.1.13": ">=1.1.13 <2",
      "brace-expansion@>=2.0.0 <2.0.3": "^2.0.3",
      "diff@<4.0.4": "^4.0.4",
      "flatted@<3.4.2": "^3.4.2",
      "markdown-it@<14.1.1": "^14.1.1",
      "minimatch@>=9.0.0 <9.0.7": "^9.0.7",
      "picomatch@<2.3.2": ">=2.3.2 <3",
      "picomatch@>=4.0.0 <4.0.4": "^4.0.4",
      "rollup@<4.59.0": "^4.59.0",
      "smol-toml@<1.6.1": "^1.6.1",
      "yaml@<2.8.3": "^2.8.3"
    }
  },
  "engines": {
    "node": ">=20"
  },
  "sideEffects": false,
  "bugs": {
    "url": "https://github.com/nyaomaru/divider/issues"
  },
  "packageManager": "pnpm@10.33.4"
}
